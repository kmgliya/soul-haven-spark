rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    function isCoupleType(v) {
      return v in ['together', 'city', 'ldr'];
    }

    function memberList(data) {
      return data.members is list ? data.members : [];
    }

    function isCoupleMember(data) {
      return authed() && request.auth.uid in memberList(data);
    }

    function isNewCoupleCreate() {
      let d = request.resource.data;
      let m = memberList(d);
      return m.size() == 1
        && m[0] == request.auth.uid
        && d.creator == request.auth.uid
        && d.coupleCode is string
        && d.coupleCode.size() >= 4
        && d.coupleCode.size() <= 8
        && isCoupleType(d.coupleType)
        && d.startDate is string
        && d.profiles is map;
    }

    function isJoinSecondMember() {
      let before = memberList(resource.data);
      let after = memberList(request.resource.data);
      return before.size() == 1
        && after.size() == 2
        && !(request.auth.uid in before)
        && request.auth.uid in after
        && after.hasAll(before)
        && request.resource.data.creator == resource.data.creator
        && request.resource.data.coupleCode == resource.data.coupleCode
        && request.resource.data.coupleType == resource.data.coupleType
        && request.resource.data.startDate == resource.data.startDate;
    }

    function isMemberCoupleUpdate() {
      return isCoupleMember(resource.data)
        && memberList(request.resource.data) == memberList(resource.data)
        && request.resource.data.creator == resource.data.creator
        && request.resource.data.coupleCode == resource.data.coupleCode
        && isCoupleType(request.resource.data.coupleType)
        && request.resource.data.startDate is string
        && request.resource.data.profiles is map;
    }

    function coupleData(coupleId) {
      return get(/databases/$(database)/documents/couples/$(coupleId)).data;
    }

    match /couples/{coupleId}/userQ36/{uid} {
      allow get: if authed() && isCoupleMember(coupleData(coupleId));
      allow create, update: if authed()
        && isCoupleMember(coupleData(coupleId))
        && request.auth.uid == uid;
      allow delete: if false;
    }

    match /couples/{coupleId} {
      // get: второй партнёр ещё не в members — ему нужно прочитать пару по coupleId из invite до join.
      allow get: if isCoupleMember(resource.data)
        || (authed() && memberList(resource.data).size() == 1);
      allow list: if isCoupleMember(resource.data);
      allow create: if authed() && isNewCoupleCreate();
      allow update: if authed() && (isJoinSecondMember() || isMemberCoupleUpdate());
      allow delete: if false;
    }

    match /couples/{coupleId}/days/{dayId} {
      allow get, list: if authed()
        && isCoupleMember(get(/databases/$(database)/documents/couples/$(coupleId)).data);
      allow create, update: if authed()
        && isCoupleMember(get(/databases/$(database)/documents/couples/$(coupleId)).data);
      allow delete: if false;
    }

    match /coupleInvites/{code} {
      allow get: if authed();
      allow list: if false;

      // Без exists/get по паре в том же batch — иначе у части проектов create инвайта отклоняется.
      allow create: if authed()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.code == code
        && request.resource.data.coupleId is string;

      allow delete: if authed()
        && resource.data.coupleId is string
        && exists(/databases/$(database)/documents/couples/$(resource.data.coupleId))
        && (
          isCoupleMember(
            get(/databases/$(database)/documents/couples/$(resource.data.coupleId)).data
          )
          || (
            memberList(
              get(/databases/$(database)/documents/couples/$(resource.data.coupleId)).data
            ).size() == 1
            && !(
              request.auth.uid
                in memberList(
                  get(/databases/$(database)/documents/couples/$(resource.data.coupleId)).data
                )
            )
          )
        );
    }

    match /users/{uid} {
      allow read, write: if authed() && request.auth.uid == uid;
    }
  }
}
