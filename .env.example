# Firebase Web SDK config (https://console.firebase.google.com -> Project settings -> Web app)
# Скопируй этот файл в .env.local и заполни значениями из Firebase консоли.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push (опционально): Firebase Console → Project settings → Cloud Messaging → Web configuration → Key pair
# После этого заполни те же ключи в public/firebase-messaging-sw.js (initializeApp).
VITE_FIREBASE_VAPID_KEY=
